{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "dist-server",
    "rootDir": "server",
    "types": ["node"],
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*.ts"]
}
